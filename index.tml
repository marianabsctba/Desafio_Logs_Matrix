<!DOCTYPE html><html lang="pt-BR"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Be Safe Academy | Matrix: O Arquiteto Mentiu</title><style>
:root{--bg:#000;--panel:rgba(0,18,8,.84);--green:#39ff6a;--dim:#8bd999;--line:rgba(57,255,106,.48);--red:#ff4d3d;--amber:#ffcc66;--text:#d5ffd9;--shadow:0 0 24px rgba(0,255,80,.2), inset 0 0 24px rgba(0,255,80,.05)}*{box-sizing:border-box}html,body{margin:0;min-height:100%;background:#000;color:var(--text);font-family:"Courier New",monospace;overflow-x:hidden}#matrixRain{position:fixed;inset:0;z-index:0;opacity:.9;pointer-events:none}.matrix-bg{position:fixed;inset:0;background:radial-gradient(circle at 50% 20%,rgba(0,255,90,.08),transparent 30%),linear-gradient(180deg,rgba(0,0,0,.18),rgba(0,0,0,.86));z-index:1;pointer-events:none}.app,.boot,.audio-hud{position:relative;z-index:2}.scanlines{position:fixed;inset:0;pointer-events:none;z-index:8;background:repeating-linear-gradient(0deg,rgba(255,255,255,.035) 0,rgba(255,255,255,.035) 1px,transparent 1px,transparent 4px);mix-blend-mode:overlay}.boot{position:fixed;inset:0;background:#000;z-index:99;display:flex;align-items:center;justify-content:center;padding:24px}.boot-card{width:min(760px,96vw);border:1px solid var(--line);box-shadow:var(--shadow);background:rgba(0,12,5,.96);padding:28px;border-radius:18px}.boot h1{font-size:clamp(34px,7vw,82px);margin:0 0 10px;color:var(--green);letter-spacing:3px;text-shadow:0 0 18px rgba(57,255,106,.8)}.boot p{color:var(--dim);line-height:1.55}.boot input,.toolbar input,.toolbar select{width:100%;padding:14px;background:#020b04;border:1px solid var(--line);border-radius:12px;color:var(--green);font:inherit;outline:none}.btn{cursor:pointer;border:1px solid var(--line);background:linear-gradient(180deg,rgba(0,80,25,.78),rgba(0,25,8,.88));color:var(--green);font:inherit;border-radius:12px;padding:12px 18px;box-shadow:0 0 12px rgba(57,255,106,.18);transition:.2s}.btn:hover{filter:brightness(1.35);box-shadow:0 0 22px rgba(57,255,106,.35)}.btn:disabled{opacity:.45;cursor:not-allowed}.app{padding:18px;max-width:1760px;margin:0 auto}.top{display:grid;grid-template-columns:1.05fr .95fr .9fr;gap:14px;margin-bottom:14px}.brand,.mission,.quote,.panel{border:1px solid var(--line);background:var(--panel);box-shadow:var(--shadow);border-radius:14px}.brand{padding:22px}.brand small{color:var(--dim);font-size:18px}.brand h1{font-size:clamp(34px,4vw,72px);line-height:.9;margin:8px 0;color:var(--green);text-shadow:0 0 18px rgba(57,255,106,.72);font-weight:700}.brand h2{font-size:clamp(18px,2vw,32px);margin:0;color:var(--green);font-weight:400}.quote{padding:18px;display:flex;align-items:center;justify-content:center;text-align:center;color:var(--green);font-size:clamp(16px,1.6vw,26px)}.mission{padding:18px}.mission b{color:var(--green)}.mission div{margin:7px 0}.layout{display:grid;grid-template-columns:320px minmax(600px,1fr) 380px;gap:14px}.panel{padding:14px;min-height:80px}.panel h3{margin:0 0 12px;color:var(--green);font-size:22px;font-weight:400;border-bottom:1px solid rgba(57,255,106,.25);padding-bottom:8px}.character-img{height:230px;border:1px solid var(--line);border-radius:12px;overflow:hidden;margin-bottom:12px;background:#000;position:relative;box-shadow:inset 0 0 28px rgba(57,255,106,.18),0 0 26px rgba(57,255,106,.12)}.character-img img{width:100%;height:100%;object-fit:cover;display:block;filter:contrast(1.08) saturate(1.03)}.character-img:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(57,255,106,.08),transparent 38%,rgba(0,0,0,.42)),repeating-linear-gradient(0deg,rgba(57,255,106,.08) 0 1px,transparent 1px 5px);mix-blend-mode:screen;pointer-events:none}.side p,.side li{color:var(--dim);line-height:1.45}.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:12px}.metric{border:1px solid rgba(57,255,106,.3);background:rgba(0,20,8,.55);padding:12px;border-radius:12px}.metric span{display:block;color:var(--dim);font-size:12px}.metric b{font-size:24px;color:var(--green)}.toolbar{display:grid;grid-template-columns:1.4fr repeat(4,1fr);gap:8px;margin-bottom:10px}.table-wrap{height:520px;overflow:auto;border:1px solid rgba(57,255,106,.28);border-radius:12px;background:rgba(0,4,2,.78)}table{width:100%;border-collapse:collapse;font-size:13px}th{position:sticky;top:0;background:#041407;color:var(--green);z-index:1;text-align:left;padding:10px;border-bottom:1px solid var(--line)}td{padding:8px 10px;border-bottom:1px solid rgba(57,255,106,.13);vertical-align:top}tr{cursor:pointer}tr:hover{background:rgba(57,255,106,.08)}tr.selected{outline:1px solid var(--green);background:rgba(57,255,106,.16)}.sev-baixo{color:#8bd999}.sev-medio{color:var(--amber)}.sev-alto,.sev-critico{color:var(--red)}.badge{display:inline-block;border:1px solid currentColor;border-radius:999px;padding:2px 8px;font-size:12px}.box{border:1px solid rgba(57,255,106,.3);border-radius:12px;padding:12px;background:rgba(0,12,5,.64);margin:10px 0}.terminal{height:180px;overflow:auto;background:#000;border:1px solid rgba(57,255,106,.35);border-radius:12px;padding:12px;color:var(--green);font-size:13px;line-height:1.45}.detail{font-size:13px;line-height:1.5;color:var(--dim);white-space:pre-wrap}.audio-hud{position:fixed;right:14px;top:14px;z-index:40;display:flex;gap:7px;align-items:center;border:1px solid var(--line);border-radius:999px;background:rgba(0,10,3,.88);padding:7px;box-shadow:var(--shadow)}.audio-hud button{width:38px;height:34px;border-radius:999px;padding:0}.audio-hud input{accent-color:#39ff6a;width:90px}.quiz-head{display:flex;justify-content:space-between;gap:10px;align-items:center}.progress{height:12px;background:#020b04;border:1px solid rgba(57,255,106,.35);border-radius:999px;overflow:hidden;margin:10px 0}.bar{height:100%;width:0;background:linear-gradient(90deg,#00c853,#39ff6a);box-shadow:0 0 14px rgba(57,255,106,.5);transition:.3s}.logchips{display:flex;gap:6px;flex-wrap:wrap;margin:10px 0}.chip{border:1px solid rgba(57,255,106,.4);padding:5px 8px;border-radius:999px;color:var(--green);cursor:pointer;background:rgba(0,20,8,.45);font-size:12px}.choices{display:grid;grid-template-columns:1fr 1fr;gap:10px}.choice{padding:13px;border:1px solid rgba(57,255,106,.35);border-radius:12px;background:rgba(0,25,8,.72);cursor:pointer;min-height:58px;display:flex;align-items:center}.choice:hover,.choice.pick{border-color:var(--green);box-shadow:0 0 18px rgba(57,255,106,.2)}.result{display:none;margin-top:14px}.result h2{color:var(--green)}.answer-card{border:1px solid rgba(57,255,106,.3);border-radius:12px;padding:12px;margin:10px 0;background:rgba(0,12,5,.7)}.ok{color:#39ff6a}.bad{color:#ff6b5d}.cert{display:none;margin-top:16px;border:1px solid var(--line);border-radius:18px;padding:14px;text-align:center;background:rgba(0,0,0,.72)}.cert h2{font-size:28px;color:var(--green);margin:6px}.cert-stage{position:relative;width:100%;max-width:1100px;margin:12px auto;border:1px solid rgba(57,255,106,.48);border-radius:14px;overflow:hidden;background:#000;box-shadow:0 0 28px rgba(57,255,106,.22)}#certLive{width:100%;display:block;background:#000}.cert-actions{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}.cert-status{font-size:13px;color:var(--dim);line-height:1.45}.muted{color:var(--dim)}.hidden{display:none!important}@media(max-width:1150px){.top,.layout{grid-template-columns:1fr}.toolbar{grid-template-columns:1fr 1fr}.table-wrap{height:450px}.metrics{grid-template-columns:repeat(2,1fr)}}@media(max-width:700px){.app{padding:10px}.choices{grid-template-columns:1fr}.toolbar{grid-template-columns:1fr}.metrics{grid-template-columns:1fr}.audio-hud{position:static;margin:10px auto;width:fit-content}.brand h1{font-size:40px}table{font-size:12px}td,th{padding:7px}}
</style></head><body>
<canvas id="matrixRain"></canvas><div class="matrix-bg"></div><div class="scanlines"></div>
<audio id="bgAudio" loop preload="auto" src="data:audio/mpeg;base64,"></audio>
<div class="audio-hud"><button class="btn" id="volDown">−</button><input id="volSlider" type="range" min="0" max="1" step=".01" value=".35"><button class="btn" id="volUp">+</button><button class="btn" id="muteBtn">🔇</button></div>
<section class="boot" id="boot"><div class="boot-card"><h1>MATRIX</h1><p>Você está prestes a entrar no SIEM da Zion Defense Grid. Digite o nome do aluno para iniciar a simulação.</p><input id="studentName" placeholder="Nome do aluno"><button class="btn" id="enterBtn">Entrar na Matrix</button></div></section>
<main class="app hidden" id="app"><section class="top"><div class="brand"><small>AULINHA MATRIX</small><h1>O ARQUITETO MENTIU</h1><h2>Threat Hunting • Correlação de logs</h2></div><div class="quote">“O ataque começou muito antes do primeiro alerta.”<br>— Oráculo</div><div class="mission"><div><b>USUÁRIO:</b> <span id="userLabel">-</span></div><div><b>NÍVEL:</b> Hunter</div><div><b>MISSÃO:</b> encontrar o evento que iniciou o ataque.</div><div class="muted">Sem dicas. Apenas logs, contexto e correlação.</div></div></section>
<section class="layout"><aside class="panel side"><h3>Morpheus</h3><div class="character-img"><img src="data:image/webp;base64,"></div><p>500 eventos foram gerados. 490 são ruído. 10 perguntas exigem correlação real.</p><div class="terminal" id="terminal"></div></aside><section class="panel"><h3>Eventos do SIEM — 500 registros</h3><div class="metrics"><div class="metric"><span>Total</span><b>500</b></div><div class="metric"><span>Ruído</span><b>490</b></div><div class="metric"><span>Importantes</span><b>10</b></div><div class="metric"><span>Nota mínima</span><b>70%</b></div></div><div class="toolbar"><input id="search" placeholder="Buscar por ID, host, usuário, domínio, processo..."><select id="sevFilter"><option value="">Severidade</option><option value="baixo">baixo</option><option value="medio">médio</option><option value="alto">alto</option><option value="critico">crítico</option></select><select id="hostFilter"><option value="">Host</option></select><select id="sourceFilter"><option value="">Fonte</option></select><button class="btn" id="clearFilters">Limpar</button></div><div class="table-wrap"><table><thead><tr><th>ID</th><th>Hora</th><th>Host</th><th>Usuário</th><th>Fonte</th><th>Evento</th><th>Detalhes</th><th>Nível</th></tr></thead><tbody id="logBody"></tbody></table></div></section><aside class="panel"><h3>Oráculo</h3><div class="character-img"><img src="data:image/webp;base64,"></div><div class="quiz-head"><b>Desafio</b><span id="qCounter">1/10</span></div><div class="progress"><div class="bar" id="bar"></div></div><div id="questionBox"></div><div class="cert-actions"><button class="btn" id="prevBtn">Anterior</button><button class="btn" id="nextBtn">Próxima</button><button class="btn" id="submitBtn" disabled>Responder</button></div></aside></section>
<section class="panel result" id="result"></section><section class="cert" id="cert"><h2>Certificado Matrix</h2><p class="cert-status">O certificado abaixo é renderizado em canvas com nome, data e hash preenchidos via JavaScript. O efeito é a chuva Matrix animada por cima do certificado.</p><div class="cert-stage"><canvas id="certLive" width="1536" height="864"></canvas></div><div class="cert-actions"><button class="btn" id="downloadCertPng">Baixar certificado PNG</button></div><p class="cert-status">A chuva Matrix continua animada na tela; o download sai em PNG preenchido e rápido.</p></section></main>
<script src="https://cdn.jsdelivr.net/npm/gif.js.optimized/dist/gif.js"></script>
<script>
const MODE='locked';
const LOGS=[{"id": "000231", "time": "07:52:11", "host": "WS-JSMITH", "user": "j.smith", "source": "Windows Security", "event": "4624 Logon", "detail": "Logon type 2 interactive. Workstation unlocked after normal business start.", "sev": "baixo"}, {"id": "000232", "time": "07:53:02", "host": "WS-JSMITH", "user": "system", "source": "Windows Update", "event": "Update check", "detail": "KB5021231 check completed. No install performed.", "sev": "baixo"}, {"id": "000233", "time": "07:53:18", "host": "FS01", "user": "backup_svc", "source": "Backup", "event": "Daily backup", "detail": "Backup job completed successfully for finance_share.", "sev": "baixo"}, {"id": "000234", "time": "07:54:09", "host": "WS-JSMITH", "user": "j.smith", "source": "Outlook", "event": "Client opened", "detail": "Outlook session created. Cached mailbox loaded.", "sev": "baixo"}, {"id": "000235", "time": "07:54:33", "host": "PRINTER01", "user": "system", "source": "Printer", "event": "Printer online", "detail": "HP LaserJet returned online after maintenance window.", "sev": "baixo"}, {"id": "000236", "time": "07:55:01", "host": "DC01", "user": "system", "source": "Windows Security", "event": "4739 Domain Policy Change", "detail": "Scheduled domain policy refresh completed. No GPO object changed.", "sev": "baixo"}, {"id": "000237", "time": "07:56:12", "host": "DNS01", "user": "-", "source": "DNS", "event": "DNS Query", "detail": "assets.company.com resolved to 10.1.20.44.", "sev": "baixo"}, {"id": "000238", "time": "07:56:45", "host": "WS-JSMITH", "user": "j.smith", "source": "Teams", "event": "Teams started", "detail": "User presence set to available.", "sev": "baixo"}, {"id": "000239", "time": "07:57:03", "host": "EDR", "user": "system", "source": "Defender", "event": "Scheduled scan", "detail": "Quick scan completed. No detection.", "sev": "baixo"}, {"id": "000240", "time": "07:58:21", "host": "WS-JSMITH", "user": "j.smith", "source": "Sysmon", "event": "Process Create", "detail": "outlook.exe -> powershell.exe -NoP -W Hidden -enc SQBFAFgA... Parent command from mail client context.", "sev": "baixo"}, {"id": "000241", "time": "07:58:22", "host": "DNS01", "user": "-", "source": "DNS", "event": "DNS Query", "detail": "cdn-office-update.com resolved to 185.199.108.153. First seen in environment.", "sev": "baixo"}, {"id": "000242", "time": "07:59:05", "host": "PROXY01", "user": "j.smith", "source": "Proxy", "event": "GET download", "detail": "GET https://cdn-office-update.com/files/office_patch.bin size=32KB user-agent PowerShell/7.3", "sev": "medio"}, {"id": "000243", "time": "08:00:11", "host": "WS-JSMITH", "user": "j.smith", "source": "Chrome", "event": "Navigation", "detail": "User opened docs.google.com. Normal browser traffic.", "sev": "baixo"}, {"id": "000244", "time": "08:02:04", "host": "WS-JSMITH", "user": "j.smith", "source": "Sysmon", "event": "File Create", "detail": "C:\\Users\\j.smith\\AppData\\Local\\Temp\\office_patch.bin written by powershell.exe.", "sev": "medio"}, {"id": "000245", "time": "08:03:48", "host": "WS-JSMITH", "user": "j.smith", "source": "Sysmon", "event": "Registry Value Set", "detail": "reg.exe add HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Run /v OneDriveUpdate /d powershell -w hidden -enc ...", "sev": "alto"}, {"id": "000246", "time": "08:05:13", "host": "WS-JSMITH", "user": "j.smith", "source": "Sysmon", "event": "Network Connection", "detail": "powershell.exe -> 185.199.108.153:443 TLS SNI cdn-office-update.com periodic 60s.", "sev": "medio"}, {"id": "000247", "time": "08:08:30", "host": "DC01", "user": "j.smith", "source": "Windows Security", "event": "4624 Logon Type 3", "detail": "Network logon from WS-JSMITH to DC01. Kerberos authentication.", "sev": "baixo"}, {"id": "000248", "time": "08:11:02", "host": "WS-JSMITH", "user": "j.smith", "source": "PowerShell", "event": "Script Block", "detail": "Get-ADComputer -Filter * -Properties OperatingSystem | select Name,OperatingSystem", "sev": "medio"}, {"id": "000249", "time": "08:13:26", "host": "WS-JSMITH", "user": "j.smith", "source": "Sysmon", "event": "Process Create", "detail": "cmd.exe /c whoami /groups", "sev": "baixo"}, {"id": "000250", "time": "08:16:50", "host": "DC01", "user": "j.smith", "source": "Windows Security", "event": "4662 Directory Query", "detail": "LDAP query filter: (servicePrincipalName=*) returning service accounts.", "sev": "medio"}, {"id": "000251", "time": "08:18:17", "host": "DC01", "user": "j.smith", "source": "Windows Security", "event": "4769 Kerberos TGS", "detail": "Service ticket requested for MSSQLSvc/sql01.company.local by j.smith.", "sev": "medio"}, {"id": "000252", "time": "08:22:41", "host": "SQL01", "user": "j.smith", "source": "Windows Security", "event": "4624 Logon Type 3", "detail": "Network logon using Kerberos from WS-JSMITH to SQL01.", "sev": "baixo"}, {"id": "000253", "time": "08:27:31", "host": "WS-JSMITH", "user": "j.smith", "source": "Sysmon", "event": "Process Create", "detail": "rundll32.exe javascript:\"\\..\\mshtml,RunHTMLApplication\" spawned by powershell.exe.", "sev": "alto"}, {"id": "000254", "time": "08:31:04", "host": "WS-JSMITH", "user": "j.smith", "source": "Sysmon", "event": "Process Create", "detail": "net.exe use \\\\FS01\\Finance /user:COMPANY\\j.smith", "sev": "baixo"}, {"id": "000255", "time": "08:36:18", "host": "FS01", "user": "j.smith", "source": "Windows Security", "event": "4663 File Access", "detail": "Read burst: finance_share/*.xlsx count=184 within 180 seconds.", "sev": "medio"}, {"id": "000256", "time": "08:40:55", "host": "WS-JSMITH", "user": "j.smith", "source": "Sysmon", "event": "Archive Created", "detail": "7z.exe a C:\\Users\\j.smith\\AppData\\Local\\Temp\\report.7z \\\\FS01\\Finance\\*.xlsx", "sev": "alto"}, {"id": "000257", "time": "08:43:32", "host": "WS-JSMITH", "user": "j.smith", "source": "Sysmon", "event": "Network Connection", "detail": "7z.exe had no network connection; powershell beacon remained active.", "sev": "baixo"}, {"id": "000258", "time": "08:50:16", "host": "PROXY01", "user": "j.smith", "source": "Proxy", "event": "POST outbound", "detail": "POST https://cdn-office-update.com/api/upload size=8.4MB content-type application/octet-stream.", "sev": "alto"}, {"id": "000259", "time": "09:05:44", "host": "EDR", "user": "system", "source": "EDR", "event": "Behavioral Alert", "detail": "Suspicious parent-child: outlook.exe -> powershell.exe observed retrospectively.", "sev": "medio"}, {"id": "000260", "time": "09:22:08", "host": "DC01", "user": "j.smith", "source": "Windows Security", "event": "4740 Account Locked", "detail": "User j.smith locked after multiple auth attempts from WS-JSMITH.", "sev": "alto"}, {"id": "000261", "time": "09:23:19", "host": "WS-JSMITH", "user": "system", "source": "Defender", "event": "Threat Detected", "detail": "Trojan.Generic in C:\\Users\\j.smith\\AppData\\Local\\Temp\\office_patch.bin", "sev": "alto"}, {"id": "000262", "time": "09:24:01", "host": "FIREWALL", "user": "-", "source": "Firewall", "event": "Egress Anomaly", "detail": "185.199.108.153:443 flagged by threat feed after correlation update.", "sev": "critico"}, {"id": "000263", "time": "09:30:19", "host": "DLP", "user": "j.smith", "source": "DLP", "event": "Possible Exfiltration", "detail": "Archive upload detected: report.7z 8.4MB to external destination.", "sev": "critico"}, {"id": "000264", "time": "09:31:02", "host": "SOC", "user": "analyst", "source": "SIEM", "event": "Incident Opened", "detail": "Correlated alert from EDR, Firewall and DLP. Case generated after observed effects.", "sev": "critico"}];
const QUESTIONS=[{"id": "q1", "text": "Qual evento provavelmente iniciou a cadeia de ataque, considerando ordem temporal, processo pai e ação subsequente?", "logs": ["000240", "000241", "000242", "000259"], "explain": "O evento 000240 é o primeiro ponto anômalo: outlook.exe dispara powershell.exe com -enc. DNS e download aparecem depois como consequência. O alerta EDR é retrospectivo e aparece mais tarde."}, {"id": "q2", "text": "Qual correlação sustenta melhor entrega de payload por uma infraestrutura disfarçada de atualização?", "logs": ["000241", "000242", "000244", "000261"], "explain": "000241 + 000242 conectam o domínio recém-observado ao download. O 000244 mostra gravação local do arquivo e o 000261 só confirma detecção posterior; o melhor par inicial é DNS seguido de download."}, {"id": "q3", "text": "Qual evidência mostra persistência inicial, e não apenas execução transitória?", "logs": ["000244", "000245", "000253", "000256"], "explain": "000245 altera HKCU\\...\\Run com OneDriveUpdate, técnica clássica de persistência por inicialização do usuário. Os outros eventos indicam criação de arquivo, execução e compactação."}, {"id": "q4", "text": "Qual sequência representa melhor descoberta interna antes de acesso a dados?", "logs": ["000249", "000250", "000251", "000252"], "explain": "A progressão correta é enumeração local, consulta LDAP por SPN, solicitação de TGS e logon de rede no SQL01. Isso mostra reconhecimento e movimento em direção a serviço interno."}, {"id": "q5", "text": "Qual evento é mais compatível com preparação para exfiltração antes do envio externo?", "logs": ["000255", "000256", "000258", "000263"], "explain": "000256 cria report.7z a partir do compartilhamento financeiro, caracterizando staging/compactação. O POST e o DLP indicam saída posterior."}, {"id": "q6", "text": "Qual correlação prova que o alerta de malware não foi o começo do incidente?", "logs": ["000240", "000246", "000259", "000261"], "explain": "000240 ocorre às 07:58:21, bem antes da detecção de Trojan às 09:23:19. A detecção é efeito tardio, não origem."}, {"id": "q7", "text": "Qual host deve ser tratado como paciente zero com base no encadeamento dos logs?", "logs": ["000240", "000247", "000252", "000258"], "explain": "WS-JSMITH concentra execução inicial, beacon, acesso ao domínio, acesso a recursos internos e envio externo. DC01, SQL01 e FS01 aparecem como alvos/recursos acessados."}, {"id": "q8", "text": "Qual evento sugere possível Kerberoasting mesmo sem o hash estar explícito no log?", "logs": ["000250", "000251", "000252", "000260"], "explain": "000251 registra TGS para MSSQLSvc/sql01.company.local. A consulta LDAP por SPN prepara o cenário, mas o pedido TGS é o artefato central para hipótese de Kerberoasting."}, {"id": "q9", "text": "Qual combinação sustenta melhor exfiltração consumada, e não apenas acesso interno ou preparação?", "logs": ["000256", "000258", "000263", "000264"], "explain": "000258 mostra POST externo de 8.4MB para o domínio suspeito e 000263 confirma alerta DLP de upload de archive. Juntos sustentam exfiltração consumada."}, {"id": "q10", "text": "Se fosse necessário bloquear o menor conjunto de indicadores para interromper a cadeia observada, qual alvo teria maior impacto imediato?", "logs": ["000241", "000246", "000258", "000262"], "explain": "O domínio/IP cdn-office-update.com / 185.199.108.153 aparece na entrega, no beacon e no upload. Bloquear esse par corta múltiplas fases observadas sem depender de bloquear um binário legítimo inteiro."}];
const CHOICES={"q1": [["000240", "PowerShell codificado iniciado pelo Outlook"], ["000241", "Consulta DNS para domínio recém-observado"], ["000242", "Download do arquivo office_patch.bin"], ["000259", "Alerta comportamental retrospectivo do EDR"]], "q2": [["000241+000242", "DNS suspeito seguido de download"], ["000240+000259", "PowerShell seguido de alerta EDR"], ["000242+000261", "Download seguido de detecção Defender"], ["000241+000262", "DNS seguido de feed do firewall"]], "q3": [["000245", "Chave Run criada via reg.exe"], ["000244", "Arquivo binário gravado em Temp"], ["000253", "rundll32 com mshtml"], ["000256", "Compactação com 7z"]], "q4": [["000249>000250>000251>000252", "whoami, LDAP SPN, TGS, logon SQL"], ["000250>000251>000249>000252", "LDAP SPN, TGS, whoami, logon SQL"], ["000251>000252>000250>000249", "TGS, logon SQL, LDAP SPN, whoami"], ["000252>000249>000250>000251", "logon SQL, whoami, LDAP SPN, TGS"]], "q5": [["000256", "Criação de report.7z"], ["000255", "Leitura massiva de XLSX"], ["000258", "POST externo de 8.4MB"], ["000263", "Alerta DLP de upload"]], "q6": [["000240<000261", "Execução codificada antes da detecção"], ["000259<000261", "EDR antes do Defender"], ["000246<000259", "Beacon antes do EDR"], ["000261<000263", "Defender antes do DLP"]], "q7": [["WS-JSMITH", "WS-JSMITH"], ["DC01", "DC01"], ["FS01", "FS01"], ["SQL01", "SQL01"]], "q8": [["000251", "4769 TGS para MSSQLSvc"], ["000250", "4662 LDAP servicePrincipalName=*"], ["000252", "4624 Logon Type 3 em SQL01"], ["000260", "4740 Account locked"]], "q9": [["000258+000263", "POST externo + alerta DLP"], ["000256+000258", "Arquivo 7z + POST externo"], ["000255+000256", "Leitura em massa + compactação"], ["000263+000264", "DLP + abertura de incidente"]], "q10": [["cdn-office-update.com/185.199.108.153", "Domínio/IP externo recorrente"], ["powershell.exe", "Binário PowerShell"], ["WS-JSMITH", "Host do usuário"], ["MSSQLSvc/sql01.company.local", "SPN do SQL"]]};
const ANSWER_VAULT={"q1": "fXFkYH1o", "q2": "fXFkYH1pBnJ1HWF1dA==", "q3": "fXFkYH1t", "q4": "fXFkYH1hE3J1HWF0dnsdY3F+YRwMAAIGf3Rm", "q5": "fXFkYHxu", "q6": "fXFkYH1oEXJ1HWF3dw==", "q7": "GhJ5GBoVZBYN", "q8": "fXFkYHxp", "q9": "fXFkYHxgBnJ1HWF3dQ==", "q10": "LiU6fyY+SysmSH40NiFMJyRiN0JfHwMOeG9la3B2HHJ9A2J0dQ=="};
const SALT='MATRIX-BE-SAFE-SALT-2026';
const CERT_IMG='data:image/webp;base64,';
let student='', idx=0, selected={}, renderedChoices={}, certDate='', certHash='', certScore=0, certPct=0, certImg=null, certAnim=null, certDrops=[];
const $=id=>document.getElementById(id);
function term(t){const el=$('terminal'); el.innerHTML += `<div>&gt; ${t}</div>`; el.scrollTop=el.scrollHeight;}
function setupRain(){const c=$('matrixRain'),ctx=c.getContext('2d');let w,h,cols,drops;function resize(){w=c.width=innerWidth;h=c.height=innerHeight;cols=Math.floor(w/16);drops=Array(cols).fill(0).map(()=>Math.random()*h/16)}resize();addEventListener('resize',resize);const chars='01アイウエオカキクケコサシスセソABCDEFGHIJKLMNOPQRSTUVWXYZ{}[]<>/=+-_$#@';setInterval(()=>{ctx.fillStyle='rgba(0,0,0,.08)';ctx.fillRect(0,0,w,h);ctx.font='16px monospace';for(let i=0;i<cols;i++){const txt=chars[Math.floor(Math.random()*chars.length)];ctx.fillStyle=Math.random()>.975?'#fff':'#39ff6a';ctx.fillText(txt,i*16,drops[i]*16);if(drops[i]*16>h&&Math.random()>.975)drops[i]=0;drops[i]++;}},42)}
function audioControls(){const a=$('bgAudio'),s=$('volSlider');a.volume=+s.value;$('volDown').onclick=()=>{a.volume=Math.max(0,a.volume-.1);s.value=a.volume};$('volUp').onclick=()=>{a.volume=Math.min(1,a.volume+.1);s.value=a.volume};s.oninput=()=>a.volume=+s.value;$('muteBtn').onclick=()=>{a.muted=!a.muted;$('muteBtn').textContent=a.muted?'🔈':'🔇'};document.body.addEventListener('click',()=>{a.play().catch(()=>{})},{once:true})}
function renderFilters(){for(const [id,key] of [['hostFilter','host'],['sourceFilter','source']]){const vals=[...new Set(LOGS.map(x=>x[key]))].sort(); vals.forEach(v=>{const o=document.createElement('option');o.value=v;o.textContent=v;$(id).appendChild(o)})}}
function renderLogs(){const q=$('search').value.toLowerCase(),sev=$('sevFilter').value,host=$('hostFilter').value,src=$('sourceFilter').value;const rows=LOGS.filter(l=>(!sev||l.sev===sev)&&(!host||l.host===host)&&(!src||l.source===src)&&(!q||Object.values(l).join(' ').toLowerCase().includes(q)));$('logBody').innerHTML=rows.map(l=>`<tr data-id="${l.id}"><td>${l.id}</td><td>${l.time}</td><td>${l.host}</td><td>${l.user}</td><td>${l.source}</td><td>${l.event}</td><td>${l.detail}</td><td><span class="badge sev-${l.sev}">${l.sev}</span></td></tr>`).join('');document.querySelectorAll('#logBody tr').forEach(tr=>tr.onclick=()=>{document.querySelectorAll('#logBody tr').forEach(x=>x.classList.remove('selected'));tr.classList.add('selected');const l=LOGS.find(x=>x.id===tr.dataset.id);term(`evento ${l.id} aberto: ${l.time} ${l.host} | ${l.event}`);});}
function shuffle(a){let x=[...a];for(let i=x.length-1;i>0;i--){let j=Math.floor(Math.random()*(i+1));[x[i],x[j]]=[x[j],x[i]]}return x}
function renderQuestion(){const q=QUESTIONS[idx];$('qCounter').textContent=`${idx+1}/10`;$('bar').style.width=`${(Object.keys(selected).length/QUESTIONS.length)*100}%`;if(!renderedChoices[q.id]) renderedChoices[q.id]=shuffle(CHOICES[q.id]); const chips=q.logs.map(id=>`<span class="chip" onclick="focusLog('${id}')">${id}</span>`).join('');const ch=renderedChoices[q.id].map(([id,label])=>`<div class="choice ${selected[q.id]===id?'pick':''}" data-answer="${id}">${label}</div>`).join('');$('questionBox').innerHTML=`<div class="box"><b>Pergunta ${idx+1}</b><p>${q.text}</p><div class="logchips">${chips}</div><div class="choices">${ch}</div></div>`;document.querySelectorAll('.choice').forEach(c=>c.onclick=()=>{selected[q.id]=c.dataset.answer;renderQuestion();});$('prevBtn').disabled=idx===0;$('nextBtn').disabled=idx===QUESTIONS.length-1;$('submitBtn').disabled=Object.keys(selected).length<QUESTIONS.length;}
function focusLog(id){$('search').value=id;renderLogs();setTimeout(()=>{const tr=document.querySelector(`#logBody tr[data-id="${id}"]`);if(tr){tr.scrollIntoView({block:'center'});tr.classList.add('selected');}},50)}
function xorDecode(b64,key){const bin=atob(b64);let out='';for(let i=0;i<bin.length;i++){out+=String.fromCharCode(bin.charCodeAt(i)^key.charCodeAt(i%key.length));}return out;}
function decodeAnswers(){return QUESTIONS.reduce((a,q)=>{a[q.id]=xorDecode(ANSWER_VAULT[q.id],SALT);return a},{})}
function grade(){const key=decodeAnswers();let score=0;QUESTIONS.forEach(q=>{if(selected[q.id]===key[q.id])score++});return {score,key}}
function labelFor(qid,aid){const item=CHOICES[qid].find(x=>x[0]===aid);return item?item[1]:'sem resposta'}
function todayBR(){return new Date().toLocaleDateString('pt-BR');}
async function sha256(text){const enc=new TextEncoder().encode(text);const buf=await crypto.subtle.digest('SHA-256',enc);return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');}
async function buildCertHash(score,pct){return (await sha256(`${student}|${score}/10|${pct}%|Matrix: O Arquiteto Mentiu|${todayBR()}|Be Safe Academy`)).slice(0,32).toUpperCase();}
function drawFitText(ctx,text,x,y,maxWidth,fontSize,align='center'){ctx.textAlign=align;let size=fontSize;do{ctx.font=`bold ${size}px Courier New`; if(ctx.measureText(text).width<=maxWidth)break; size-=2;}while(size>22);ctx.fillText(text,x,y);}
function ensureCertDrops(){if(certDrops.length)return;for(let x=0;x<1536;x+=22){certDrops.push({x,y:Math.random()*864,s:12+Math.random()*14,spd:4+Math.random()*10,a:.25+Math.random()*.55})}}
function renderCertFrame(t=0,ctx=null){const c=$('certLive'); ctx=ctx||c.getContext('2d'); ctx.clearRect(0,0,c.width,c.height); if(certImg)ctx.drawImage(certImg,0,0,c.width,c.height); ctx.save();ctx.globalCompositeOperation='source-over';ctx.fillStyle='rgba(0,0,0,.05)';ctx.fillRect(0,0,c.width,c.height);ensureCertDrops();const chars='01ABCDEFGHIJKLMNOPQRSTUVWXYZアイウエオカキクケコ';ctx.font='22px Courier New';for(const d of certDrops){d.y+=d.spd;if(d.y>c.height+80){d.y=-80;d.x=Math.random()*c.width}for(let k=0;k<8;k++){const yy=d.y-k*d.s; if(yy<0||yy>c.height)continue;ctx.fillStyle=k===0?`rgba(220,255,220,${d.a})`:`rgba(57,255,106,${Math.max(.05,d.a-k*.07)})`;ctx.font=`${d.s}px Courier New`;ctx.fillText(chars[Math.floor(Math.random()*chars.length)],d.x,yy)}}ctx.restore();ctx.save();ctx.shadowColor='#39ff6a';ctx.shadowBlur=18;ctx.fillStyle='#caffcf';drawFitText(ctx,student||'ALUNO',768,365,720,48,'center');ctx.font='bold 26px Courier New';ctx.textAlign='left';ctx.fillText('DATA: '+certDate,970,635);ctx.font='bold 20px Courier New';drawFitText(ctx,'HASH: '+certHash,1100,700,560,22,'center');ctx.textAlign='center';ctx.font='bold 18px Courier New';ctx.fillText(`${certScore}/10 • ${certPct}%`,768,805);ctx.restore();}
async function prepareCertificate(score,pct){certScore=score;certPct=pct;certDate=todayBR();certHash=await buildCertHash(score,pct);certImg=new Image();certImg.onload=()=>{renderCertFrame(); if(certAnim)cancelAnimationFrame(certAnim); const loop=(ts)=>{renderCertFrame(ts);certAnim=requestAnimationFrame(loop)};certAnim=requestAnimationFrame(loop)};certImg.src=CERT_IMG;}
async function submitQuiz(){const {score,key}=grade();const pct=Math.round(score/QUESTIONS.length*100);const pass=pct>=70;let html=`<h2>${pass?'Acesso concedido':'Acesso negado'} — ${score}/10 (${pct}%)</h2><p>${pass?'Você encontrou a história por trás dos alertas.':'Você viu alertas, mas ainda precisa reconstruir melhor a cadeia.'}</p><h3>Respostas corretas explicadas</h3>`;QUESTIONS.forEach((q,i)=>{const ok=selected[q.id]===key[q.id];html+=`<div class="answer-card"><b>${i+1}. ${ok?'<span class="ok">Correta</span>':'<span class="bad">Incorreta</span>'}</b><p>${q.text}</p><p><b>Sua resposta:</b> ${labelFor(q.id,selected[q.id])}</p><p><b>Resposta correta:</b> ${labelFor(q.id,key[q.id])}</p><p class="muted">${q.explain}</p></div>`});$('result').style.display='block';$('result').innerHTML=html;if(pass||MODE==='unlocked'){await prepareCertificate(score,pct);$('cert').style.display='block';term(MODE==='unlocked'&&!pass?'certificado liberado em modo teste':'certificado liberado');}else{$('cert').style.display='none';term('certificado bloqueado: mínimo 70%');}$('result').scrollIntoView({behavior:'smooth'});}
function downloadPNG(){const a=document.createElement('a');a.href=$('certLive').toDataURL('image/png');a.download='certificado_matrix_be_safe.png';a.click()}
function init(){setupRain();audioControls();renderFilters();renderLogs();['search','sevFilter','hostFilter','sourceFilter'].forEach(id=>$(id).addEventListener('input',renderLogs));$('clearFilters').onclick=()=>{$('search').value='';$('sevFilter').value='';$('hostFilter').value='';$('sourceFilter').value='';renderLogs()};$('enterBtn').onclick=()=>{student=$('studentName').value.trim();if(!student){alert('Digite o nome do aluno.');return}$('userLabel').textContent=student;$('boot').classList.add('hidden');$('app').classList.remove('hidden');term(`sessão iniciada para ${student}`);term('carregando 500 eventos; 490 classificados como ruído');renderQuestion();$('bgAudio').play().catch(()=>{})};$('prevBtn').onclick=()=>{if(idx>0){idx--;renderQuestion()}};$('nextBtn').onclick=()=>{if(idx<QUESTIONS.length-1){idx++;renderQuestion()}};$('submitBtn').onclick=submitQuiz;$('downloadCertPng').onclick=downloadPNG;}
document.addEventListener('DOMContentLoaded',init);
</script></body></html>
